    "clock": {
      "interval": 1,
      // "format-alt": "´ü│ {:%d-%m-%Y}",
      "format": "{:%H:%M, %d-%m-%Y}",
      "tooltip-format": "{:%e %B %Y}",
      "on-click": "gnome-calendar"
    },
    "sway/mode": {
      "format": "{}",
      "tooltip": false
    },
    "sway/workspaces": {
      "disable-scroll": true,
      "disable-markup": false,
      "all-outputs": true,
      "format": "<span font='10'>{icon}</span>",
      "format-icons": {
        "1": "´âá",
        "2": "´éć",
        "3": "´ëę",
        "4": "´äá",
        "5": "´äí",
        "6": "´íî",
        "10": "´ć╝"
      }
    },
    "tray": {
      "icon-size": 16,
      "spacing": 10
    },
    "custom/power": {
      "format": "<span font='12'>´ÇĹ</span>",
      "on-click": "exec ~/.config/waybar/scripts/power-menu.sh",
      "tooltip": false
    },
    "network": {
      "interval": 5,
      "format-wifi": "{essid} ({signalStrength}%) ´çź", // Icon: wifi
      "format-ethernet": "{ifname}: {ipaddr}/{cidr} ´âČ", // Icon: ethernet
      "format-disconnected": "Disconnected ÔÜá",
      "tooltip-format": "{ifname}: {ipaddr}",
      //      "on-click": "alacritty -e 'nmtui'",
    },
    "network#vpn": {
      "interface": "tun0",
      "format": "´Çĺ  {essid} ({signalStrength}%)",
      "format-disconnected": "ÔÜá  Disconnected",
      "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
      "interval": 5,
    },
    "bluetooth": {
	    "format": "´Őö",
	    "format-connected": "´Őö {device_alias}",
	    "format-connected-battery": "´Őö {device_alias} {device_battery_percentage}%",
	    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
	    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
	    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
	    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%"
    },
    "custom/spotify": {
      "exec": "/usr/bin/python3 ~/.config/waybar/scripts/mediaplayer.py --player spotify",
      "format": "{} <span font='12'>´ć╝</span>",
      "return-type": "json",
      "on-click": "playerctl --player=spotify play-pause",
      "on-scroll-up": "playerctl --player=spotify next",
      "on-scroll-down": "playerctl --player=spotify previous"
    }
  },
  {
    "layer": "top",
    "position": "bottom",
    "height": 25,
    "modules-left": [
      "cpu",
      "memory",
      "disk",
      "custom/fanspeed",
      "temperature",
    ],
    "modules-center": [],
    "modules-right": [
      "network#vpn_vrs",
      "network#vpn_streamsage",
      "network#vpn_office",
      "pulseaudio",
      "backlight",
    ],
    "network#vpn_vrs": {
      "interface": "vrs",
      "format": "VRS [{ipaddr}/{cidr}] ´Çú",
      "format-disconnected": "",
      "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
    },
    "network": {
      "interval": 5,
      "format-wifi": "{essid} ({signalStrength}%) ´çź", // Icon: wifi
      "format-ethernet": "{ifname}: {ipaddr}/{cidr} ´âČ", // Icon: ethernet
      "format-disconnected": "Disconnected ÔÜá",
      "tooltip-format": "{ifname}: {ipaddr}",
    },
    "network#vpn_streamsage": {
      "interface": "tun0",
      "format": "VPC [{ipaddr}/{cidr}] ´Çú",
      "format-disconnected": "",
      "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
    },
    "network#vpn_office": {
      "interface": "ppp0",
      "format": "GL #1 [{ipaddr}/{cidr}] ´Çú",
      "format-disconnected": "",
      "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
    },
    "temperature": {
      "interval": 5,
      "format": "{temperatureC}┬░C ´őë",
      "interval": 3
    },
    "custom/fanspeed": {
      "format": "{} ´őť",
      "exec": "$HOME/.config/waybar/scripts/fanspeed.sh",
      "interval": 3
    },
    "backlight": {
      "device": "intel_backlight",
      "format": "{percent}% {icon}",
      "format-icons": [
        "´âź",
        "´âź"
      ]
    },
    "pulseaudio": {
      "scroll-step": 1,
      "format": "{volume}% <span font='11'>{icon}</span>",
      "format-bluetooth": "{volume}% <span font='11'>{icon} ´Őö</span>",
      "format-muted": "´ÇŽ Muted",
      "format-icons": {
        "headphones": " ´Çą",
        "handsfree": "´ľÉ",
        "headset": "´ľÉ",
        "phone": " ´éĽ",
        "portable": " ´éĽ",
        "car": " ´ć╣",
        "default": [
          "´Çž",
          "´ÇĘ"
        ]
      },
      "on-click": "pavucontrol",
      "on-scroll-up": "pactl set-sink-volume 0 +2%",
      "on-scroll-down": "pactl set-sink-volume 0 -2%"
    },
    "memory": {
      "interval": 5,
      "format": "RAM: {used:0.1f}/{total:0.1f}G", // Icon: memory
      "on-click": "alacritty -e 'htop'",
      "states": {
        "warning": 70,
        "critical": 90
      }
    },
    "cpu": {
      "interval": 5,
      "format": "CPU: {usage}%",
      "states": {
        "warning": 70,
        "critical": 90,
      },
      "on-click": "alacritty -e 'htop'",
    },
    "disk": {
      "interval": 30,
      "format": "{used}/{total} ({percentage_used}%)",
      "path": "/"
    },
  }
]
