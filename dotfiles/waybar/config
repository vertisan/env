[
  {
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": [
      "sway/mode",
      "bluetooth",
      "custom/spotify"
    ],
    "modules-center": [
      "sway/workspaces"
    ],
    "modules-right": [
      "idle_inhibitor",
      // "network",
      "battery",
      "clock",
      "tray",
      "custom/power"
    ],
    "idle_inhibitor": {
      "format": "<span font='12'>{icon}</span>",
      "format-icons": {
        "activated": "´ü«",
        "deactivated": "´ü░"
      }
    },
    "battery": {
      "states": {
        "good": 90,
        "warning": 25,
        "critical": 15
      },
      "format": "{capacity}% <span font='12'>{icon}</span>",
      "format-full": "<span font='12'>´ëÇ</span>",
      "format-icons": [
        "´ëä",
        "´ëâ",
        "´ëé",
        "´ëü",
        "´ëÇ"
      ]
