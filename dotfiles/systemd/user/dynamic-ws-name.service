[Unit]
Description=Dynamic renaming Sway workspaces based on the currently focused content.
Documentation=https://vrs-factory.dev
PartOf=sway-session.target

[Service]
Type=simple
Environment="XDG_CURRENT_DESKTOP=sway"
ExecStart=/home/vertisan/.config/sway/bin/dynamic-ws-name.py
ExecReload=kill -SIGUSR2 $MAINPID
ExecStop=/bin/kill -2 $MAINPID
Restart=on-failure
RestartSec=1
TimeoutStopSec=10

[Install]
WantedBy=sway-session.target
